<!-- Service Control -->
<div class="bbui-section">
  <div class="bbui-section-header">
    ⚙ Service Control
  </div>
  <div class="bbui-body">
    <div class="bbui-runtime <?= $python_ok ? 'ok' : 'warn' ?>">
      <strong>Python Runtime:</strong>
      <?php if ($python_ok): ?>
        OK, Python <?= htmlspecialchars($python_status['version']) ?> unter <code><?= htmlspecialchars($python_status['path']) ?></code>
      <?php else: ?>
