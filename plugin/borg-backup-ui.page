    <script>
    function bbui_action(action) {
      var labels = {start:'STARTING...', stop:'STOPPING...', restart:'RESTARTING...'};
      document.getElementById('bbui-dot').className = 'bbui-dot pending';
      document.getElementById('bbui-status-text').textContent = labels[action] || '...';
      document.getElementById('bbui-ctrl-btns').innerHTML = '<span style="color:#888;font-size:13px">&#8987; Bitte warten...</span>';
      document.getElementById('bbui-open-row').innerHTML = '';
      fetch('?action=' + action, {credentials: 'same-origin'}).catch(function(){});
      setTimeout(function(){ location.reload(); }, action === 'restart' ? 2500 : 1500);
    }
    </script>

