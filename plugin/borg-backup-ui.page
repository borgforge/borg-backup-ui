<?PHP
$PLUGIN_DIR = "/boot/config/plugins/borg-backup-ui";
$CONF_FILE  = "$PLUGIN_DIR/borg_backup_ui.conf";
$PIDFILE    = "/var/run/borg_backup_ui.pid";
$RC         = "/etc/rc.d/rc.borg_backup_ui";

function bbui_is_running($pidfile) {
  if (!file_exists($pidfile)) return false;
  $pid = trim(file_get_contents($pidfile));
  return $pid && file_exists("/proc/$pid");
}

function bbui_read_conf($file) {
  $conf = ['PORT' => '8765', 'BIND' => '0.0.0.0'];
  if (!file_exists($file)) return $conf;
  foreach (file($file, FILE_IGNORE_NEW_LINES) as $line) {
    $line = trim($line);
    if ($line === '' || $line[0] === '#') continue;
    if (preg_match('/^([A-Z_]+)=(.*)$/', $line, $m)) $conf[$m[1]] = $m[2];
  }
  return $conf;
}

function bbui_write_conf($file, $port, $bind) {
  if (!file_exists($file)) {
    file_put_contents($file, "PORT=$port\nBIND=$bind\n");
    return;
  }
  $lines = file($file, FILE_IGNORE_NEW_LINES);
  $port_set = $bind_set = false;
  foreach ($lines as &$line) {
    if (preg_match('/^PORT=/', $line)) { $line = "PORT=$port"; $port_set = true; }
    if (preg_match('/^BIND=/', $line)) { $line = "BIND=$bind"; $bind_set = true; }
  }
  if (!$port_set) $lines[] = "PORT=$port";
  if (!$bind_set) $lines[] = "BIND=$bind";
  file_put_contents($file, implode("\n", $lines) . "\n");
}

function bbui_python_runtime_status() {
  $path = trim((string)shell_exec("command -v python3 2>/dev/null"));
  $status = [
    'ok' => false,
    'path' => $path,
    'version' => '',
    'reason' => '',
    'min_version' => '3.10',
  ];
  if ($path === '') {
    $status['reason'] = 'Python 3 nicht gefunden.';
    return $status;
  }
  if (!is_executable($path)) {
    $status['reason'] = "python3 ist nicht ausführbar: $path";
    return $status;
  }
  $cmd = escapeshellarg($path) . " -c " . escapeshellarg("import sys; print('.'.join(map(str, sys.version_info[:3]))); raise SystemExit(0 if sys.version_info >= (3, 10) else 1)") . " 2>/dev/null";
  $lines = [];
  $rc = 1;
  exec($cmd, $lines, $rc);
  $version = trim((string)($lines[0] ?? ''));
  $status['version'] = $version;
  if ($version === '') {
    $status['reason'] = "Python-Version konnte nicht ermittelt werden.";
    return $status;
  }
  if ($rc !== 0) {
    $status['reason'] = "Python $version ist zu alt. Erforderlich ist Python 3.10 oder neuer.";
    return $status;
  }
  $status['ok'] = true;
  return $status;
}

// Version from .plg file
$version = '';
$plg = "/boot/config/plugins/borg-backup-ui.plg";
if (file_exists($plg)) {
  $plg_content = file_get_contents($plg);
  if (preg_match('/<!ENTITY version\s+"([^"]+)"/', $plg_content, $m)) $version = $m[1];
}

// Aktionen via GET-Parameter (Unraid fängt form-POST ab und öffnet neues Fenster)
// Kein sleep() hier – JS zeigt Loading-State und lädt nach Delay neu
$action = $_GET['action'] ?? ($_POST['action'] ?? '');
$python_status = bbui_python_runtime_status();
$python_ok = $python_status['ok'];
$warn_msg = '';

if (($action === 'start' || $action === 'restart') && !$python_ok) {
  $warn_msg = $python_status['reason'] . " Bitte zuerst das Plugin 'Python 3 for Unraid' installieren oder aktualisieren.";
} elseif ($action === 'start') {
  shell_exec("$RC start >/dev/null 2>&1 &");
} elseif ($action === 'stop') {
  shell_exec("$RC stop >/dev/null 2>&1 &");
} elseif ($action === 'restart') {
  shell_exec("$RC restart >/dev/null 2>&1 &");
} elseif ($action === 'apply' || $action === 'default') {
  if ($action === 'default') {
    $port = '8765'; $bind = '0.0.0.0';
  } else {
    $port = intval($_POST['PORT'] ?? 8765);
    $bind = in_array($_POST['BIND'] ?? '', ['0.0.0.0', '127.0.0.1']) ? $_POST['BIND'] : '0.0.0.0';
    if ($port < 1 || $port > 65535) $port = 8765;
  }
  bbui_write_conf($CONF_FILE, $port, $bind);
  shell_exec("$RC restart >/dev/null 2>&1 &");
}

$running = bbui_is_running($PIDFILE);
$conf    = bbui_read_conf($CONF_FILE);
$port    = $conf['PORT'];
$bind    = $conf['BIND'];
$ip      = $_SERVER['SERVER_ADDR'];
$ui_url  = "http://$ip:$port";
?>
