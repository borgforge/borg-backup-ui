      <strong id="bbui-status-text"><?= $running ? 'RUNNING' : 'STOPPED' ?></strong>
      <?php if ($version): ?>
        <span class="bbui-version">v<?= htmlspecialchars($version) ?></span>
      <?php endif ?>
    </div>

    <div class="bbui-btn-row" id="bbui-open-row">
      <?php if ($running): ?>
        <a href="<?= htmlspecialchars($ui_url) ?>" target="_blank" class="bbui-btn primary">
          &#10149; Borg Backup UI öffnen
        </a>
      <?php endif ?>
    </div>

    <br>

    <div class="bbui-btn-row" id="bbui-ctrl-btns">
      <?php if ($running): ?>
        <button type="button" class="bbui-btn danger" onclick="bbui_action('stop')">&#9632; Stop</button>
        <button type="button" class="bbui-btn"        onclick="bbui_action('restart')" <?= $python_ok ? '' : 'disabled title="Python 3 fehlt oder ist zu alt"' ?>>&#8635; Restart</button>
      <?php else: ?>
        <button type="button" class="bbui-btn primary" onclick="bbui_action('start')" <?= $python_ok ? '' : 'disabled title="Python 3 fehlt oder ist zu alt"' ?>>&#9654; Start</button>
      <?php endif ?>
